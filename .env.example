# Telegram Bot配置
TELEGRAM_BOT_TOKEN=你的机器人TOKEN
ADMIN_IDS=你的TelegramID,管理员ID2

# 游戏规则配置
MIN_AMOUNT=20
MAX_AMOUNT=1000
MIN_PACKET_COUNT=1
MAX_PACKET_COUNT=10
DEFAULT_PACKET_COUNT=10
COMMISSION_RATE=0.05

# 数据库配置 (建议使用本地SQLite，无需安装MySQL)
DB_TYPE=sqlite
DB_NAME=bot_data.db

# 应用配置
APP_ENV=production
LOG_LEVEL=INFO
